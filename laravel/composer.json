{
  "name": "grpc-sample/laravel",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0",
    "guzzlehttp/guzzle": "^7.0",
    "grpc/grpc": "^1.57",
    "google/protobuf": "^4.0",
    "open-telemetry/api": "1.0",
    "open-telemetry/sdk": "1.0",
    "open-telemetry/exporter-otlp": "1.0",
    "nyholm/psr7": "1.8",
    "symfony/http-client": "7.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "User\\": "app/Grpc/User/",
      "GPBMetadata\\": "app/Grpc/GPBMetadata/"
    }
  }
}
